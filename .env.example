# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Hugging Face token (read+write) for pulling gated models and pushing your dataset/model.
# Create at https://huggingface.co/settings/tokens
HF_TOKEN=

# Frontier "teacher" model used for (a) data distillation and (b) the LLM-as-judge.
# Use whichever provider you have covered credits for.
TEACHER_API_KEY=
TEACHER_MODEL=

# Your Hub namespaces (used by build_dataset.py and the model push).
HF_DATASET_REPO=your-username/keigo-register-jp-en
HF_MODEL_REPO=your-username/keigo-slm-qwen3-1.7b
